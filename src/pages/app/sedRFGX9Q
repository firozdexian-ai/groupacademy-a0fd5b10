import React, { useEffect, useRef, useState } from "react";
import { useParams, useNavigate } from "react-router-dom";
import { useQuery } from "@tanstack/react-query";
import { ArrowLeft, Send, Sparkles, Loader2, AlertCircle, Building2, BookOpen } from "lucide-react";
import { supabase } from "@/integrations/supabase/client";
import { Card, CardContent } from "@/components/ui/card";
import { Button } from "@/components/ui/button";
import { Input } from "@/components/ui/input";
import { Skeleton } from "@/components/ui/skeleton";
import { toast } from "sonner";
import { cn } from "@/lib/utils";
import { RoadmapBuilderSheet } from "@/components/abroad/RoadmapBuilderSheet";

// Production Data Contracts[cite: 8]
interface DestinationAgent {
  id: string;
  country_code: string;
  display_name: string;
  tagline: string | null;
  flag_emoji: string | null;
}

interface Program {
  id: string;
  university_name: string;
  program_name: string;
  degree_type: string | null;
  tuition_range: string | null;
}

interface AgentMessage {
  role: "user" | "assistant";
  content: string;
}

export default function DestinationAgentPage() {
  const { country } = useParams<{ country: string }>();
  const navigate = useNavigate();
  const countryCode = (country || "").toUpperCase();

  const [messages, setMessages] = useState<AgentMessage[]>([
    { role: "assistant", content: `I am your specialized advisor for ${countryCode}. How can I assist with your study abroad roadmap?` },
  ]);
  const [input, setInput] = useState("");
  const [sending, setSending] = useState(false);
  const scrollRef = useRef<HTMLDivElement>(null);

  // Digital Workforce Anomaly Reporting[cite: 6]
  const reportAnomaly = async (event: string, context: any) => {
    console.error(`[Digital Workforce Anomaly] ${event}`, context);
    await supabase.functions.invoke("admin-support-assistant", {
      body: { type: "abroad_agent_error", event, context }
    });
  };

  const { data: agent, isLoading: agentLoading } = useQuery({
    queryKey: ["destination-agent", countryCode],
    queryFn: async () => {
      const { data, error } = await supabase
        .from("destination_agents")
        .select("id, country_code, display_name, tagline, flag_emoji")
        .eq("country_code", countryCode)
        .maybeSingle();
      if (error) {
        await reportAnomaly("AgentFetchError", { countryCode, error });
        throw error;
      }
      return data as DestinationAgent | null;
    }
  });

  const { data: programs = [] } = useQuery({
    queryKey: ["abroad-programs", countryCode],
    queryFn: async () => {
      const { data, error } = await supabase
        .from("study_abroad_programs")
        .select("id, university_name, program_name, degree_type, tuition_range")
        .eq("country_code", countryCode)
        .eq("is_active", true)
        .limit(10);
      if (error) {
        await reportAnomaly("ProgramFetchError", { countryCode, error });
        throw error;
      }
      return data as Program[] || [];
    }
  });

  useEffect(() => {
    scrollRef.current?.scrollTo({ top: scrollRef.current.scrollHeight, behavior: "smooth" });
  }, [messages, sending]);

  const sendMessage = async () => {
    if (!input.trim() || sending) return;
    const text = input;
    setInput("");
    const nextMessages = [...messages, { role: "user" as const, content: text }];
    setMessages(nextMessages);
    setSending(true);

    try {
      const { data, error } = await supabase.functions.invoke("ai-agent-chat", {
        body: { messages: nextMessages, agent_key: `abroad-${countryCode.toLowerCase()}` }
      });
      if (error) throw error;
      setMessages((prev) => [...prev, { role: "assistant", content: data.reply }]);
    } catch (e) {
      await reportAnomaly("AgentChatFailure", { error: e });
      toast.error("Communication channel interrupted.");
    } finally {
      setSending(false);
    }
  };

  return (
    <div className="max-w-4xl mx-auto px-6 py-10 pb-40 space-y-8 animate-in fade-in duration-700">
      <header className="flex items-center gap-4">
        <Button variant="ghost" size="icon" className="h-11 w-11 rounded-xl" onClick={() => navigate("/app/abroad")}>
          <ArrowLeft className="h-5 w-5" />
        </Button>
        {agent ? (
          <div>
            <h1 className="text-2xl font-black uppercase tracking-tighter italic">{agent.display_name} {agent.flag_emoji}</h1>
            <p className="text-[10px] font-bold text-muted-foreground uppercase tracking-widest">{agent.tagline}</p>
          </div>
        ) : <Skeleton className="h-10 w-48" />}
      </header>

      <div className="grid gap-8 md:grid-cols-2">
        <section className="space-y-4">
          <h2 className="text-xs font-black uppercase tracking-[0.3em] text-primary italic">Active Logic Nodes</h2>
          <div className="h-[500px] flex flex-col border-2 border-border/40 rounded-[32px] bg-card/30 backdrop-blur-sm overflow-hidden">
            <div ref={scrollRef} className="flex-1 overflow-y-auto p-6 space-y-4">
              {messages.map((m, i) => (
                <div key={i} className={cn("text-sm p-4 rounded-2xl italic", m.role === "user" ? "bg-primary text-primary-foreground ml-8" : "bg-muted mr-8")}>
                  {m.content}
                </div>
              ))}
              {sending && <Loader2 className="h-6 w-6 animate-spin text-primary" />}
            </div>
            <div className="p-4 border-t border-border/10 flex gap-2">
              <Input value={input} onChange={(e) => setInput(e.target.value)} placeholder="Query agent..." className="rounded-xl" />
              <Button size="icon" onClick={sendMessage} disabled={sending} className="rounded-xl"><Send className="h-4 w-4" /></Button>
            </div>
          </div>
        </section>

        <section className="space-y-4">
          <div className="flex items-center justify-between">
            <h2 className="text-xs font-black uppercase tracking-[0.3em] text-primary italic">Program Registry</h2>
            <RoadmapBuilderSheet />
          </div>
          <div className="space-y-3">
            {programs.map((p) => (
              <Card key={p.id} className="rounded-2xl border-2 border-border/40 hover:border-primary/40 transition-all">
                <CardContent className="p-4 flex gap-4">
                  <div className="h-12 w-12 rounded-xl bg-primary/10 flex items-center justify-center shrink-0">
                    <BookOpen className="h-5 w-5 text-primary" />
                  </div>
                  <div>
                    <p className="text-sm font-black uppercase italic leading-none">{p.university_name}</p>
                    <p className="text-[10px] font-bold text-muted-foreground mt-1 uppercase tracking-widest">{p.program_name}</p>
                  </div>
                </CardContent>
              </Card>
            ))}
          </div>
        </section>
      </div>
    </div>
  );
}